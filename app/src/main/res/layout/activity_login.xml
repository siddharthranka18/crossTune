<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <ImageView
        android:id="@+id/headerImage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_login_hero"
        app:layout_constraintHeight_percent="0.45"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-80dp"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerImage">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back!"
                android:layout_gravity="center"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />


            <View android:layout_width="match_parent" android:layout_height="32dp"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Username"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="@android:drawable/editbox_background_normal"/>

            <View android:layout_width="match_parent" android:layout_height="12dp"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Password"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="@android:drawable/editbox_background_normal"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSignIn"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="20dp"
                android:text="Sign In"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/gradient_signin" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Or Sign in with"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:textColor="#555555" />

            <!-- Spotify - dark with green border -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSpotifyDummy"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:text="Sign in with Spotify"
                android:textAllCaps="false"
                android:textColor="#1DB954"
                app:backgroundTint="#1A1A1A"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_spotify"
                app:iconGravity="textStart"
                app:iconTint="@null"
                app:iconPadding="12dp"
                app:iconSize="28dp"
                app:strokeColor="#1DB954"
                app:strokeWidth="1.5dp" />

            <!-- YTM - dark with red border -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnYTDummy"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:text="Sign in with YT Music"
                android:textAllCaps="false"
                android:textColor="#FF0000"
                app:backgroundTint="#1A1A1A"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_youtube"
                app:iconGravity="textStart"
                app:iconTint="@null"
                app:iconPadding="12dp"
                app:iconSize="28dp"
                app:strokeColor="#FF0000"
                app:strokeWidth="1.5dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>